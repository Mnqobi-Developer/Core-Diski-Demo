@{
    ViewData["Title"] = "Home";
}

<section class="hero-panel mb-4">
    <h1 class="display-5 store-title">Authentic Football Shirts, Premium Matchday Style</h1>
    <p class="col-lg-8 fs-5 text-muted">Discover elite club jerseys, retro classics, and top South African fan favourites. Built for football lovers who want style and authenticity.</p>
    <div class="d-flex gap-2">
        <a asp-controller="Products" asp-action="Index" class="btn btn-store px-4" style="max-width:220px;">Shop the Collection</a>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark px-4">View Cart</a>
    </div>
</section>
<div class="p-5 mb-4 bg-light rounded-3 border">
    <div class="container-fluid py-3">
        <h1 class="display-6 fw-bold">Football Shirts Store</h1>
        <p class="col-md-9 fs-5">Browse top soccer shirts, add to cart, and checkout with South African payment options like PayFast, Ozow, Yoco, and Peach Payments.</p>
        <div class="d-flex gap-2">
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg">Shop Shirts</a>
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark btn-lg">View Cart</a>
        </div>
        <p class="col-md-9 fs-5">Admin-first catalog setup is ready. Login as admin, add leagues/clubs/brands/categories, then add your soccer jerseys.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">Admin Login</a>
    </div>
</div>
