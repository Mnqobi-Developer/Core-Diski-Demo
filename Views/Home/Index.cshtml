@{
    ViewData["Title"] = "Home";
}

<section class="hero-panel mb-4">
    <h1 class="display-5 store-title">Authentic Football Shirts, Premium Matchday Style</h1>
    <p class="col-lg-8 fs-5 text-muted">Discover elite club jerseys, retro classics, and top South African fan favourites. Built for football lovers who want style and authenticity.</p>
    <div class="d-flex gap-2">
        <a asp-controller="Products" asp-action="Index" class="btn btn-store px-4" style="max-width:220px;">Shop the Collection</a>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark px-4">View Cart</a>
    </div>
</section>
