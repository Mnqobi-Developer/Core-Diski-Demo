@model Core_Diski_Demo.Models.ViewModels.Checkout.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<h1 class="h3 mb-3">Checkout</h1>
<p class="text-muted">Choose a South African payment option and confirm delivery details.</p>

<form method="post" class="card card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="ShippingAddress" class="form-label"></label>
        <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Street, suburb, city, province, postal code"></textarea>
        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
        <select asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<Core_Diski_Demo.Models.ViewModels.Checkout.CheckoutPaymentMethod>()" class="form-select"></select>
        <small class="text-muted">Supported options: PayFast, Ozow, Yoco, Peach Payments, Manual EFT.</small>
    </div>

    <div class="alert alert-light border">Order Total: <strong>@Model.TotalAmount.ToString("C")</strong></div>

    <button class="btn btn-primary">Confirm & Continue</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
