@model Core_Diski_Demo.Models.ViewModels.Products.ProductIndexViewModel
@{
    ViewData["Title"] = "Shop Soccer Shirts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Shop Soccer Shirts</h1>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark">View Cart</a>
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-2">
        <div class="col-md-3"><input asp-for="Query" class="form-control" placeholder="Search by club, shirt, league, brand..." /></div>
        <div class="col-md-2">
            <select asp-for="LeagueId" class="form-select">
                <option value="">All leagues</option>
                @foreach (var item in Model.Leagues) { <option value="@item.Id">@item.Name</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select asp-for="ClubId" class="form-select">
                <option value="">All clubs</option>
                @foreach (var item in Model.Clubs) { <option value="@item.Id">@item.Name</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select asp-for="BrandId" class="form-select">
                <option value="">All brands</option>
                @foreach (var item in Model.Brands) { <option value="@item.Id">@item.Name</option> }
            </select>
        </div>
        <div class="col-md-3">
            <select asp-for="CategoryId" class="form-select">
                <option value="">All shirt types</option>
                @foreach (var item in Model.Categories) { <option value="@item.Id">@item.Name</option> }
            </select>
        </div>
        <div class="col-md-2"><input asp-for="MinPrice" class="form-control" placeholder="Min price" /></div>
        <div class="col-md-2"><input asp-for="MaxPrice" class="form-control" placeholder="Max price" /></div>
        <div class="col-md-2">
            <select asp-for="SizeId" class="form-select">
                <option value="">All sizes</option>
                @foreach (var item in Model.Sizes) { <option value="@item.Id">@item.Name</option> }
            </select>
        </div>
        <div class="col-md-3 d-grid"><button class="btn btn-primary">Apply Filters</button></div>
        <div class="col-md-3 d-grid"><a asp-action="Index" class="btn btn-outline-secondary">Reset</a></div>
    </div>
</form>

<div class="row g-3">
    @if (!Model.Products.Any())
    {
        <div class="col-12"><div class="alert alert-info">No shirts found with the selected filters.</div></div>
    }

    @foreach (var product in Model.Products)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="card-img-top" style="height:220px;object-fit:cover;" alt="@product.Name" />
                }
                <div class="card-body d-flex flex-column">
                    <h2 class="h6">@product.Name</h2>
                    <div class="small text-muted">@product.League • @product.Club • @product.Brand</div>
                    <div class="mt-2 fw-bold">@product.Price.ToString("C")</div>
                    <div class="small @(product.StockQuantity > 0 ? "text-success" : "text-danger")">
                        @(product.StockQuantity > 0 ? $"In stock ({product.StockQuantity})" : "Out of stock")
                    </div>
                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary mt-auto">View Details</a>
                </div>
            </div>
        </div>
    }
</div>
