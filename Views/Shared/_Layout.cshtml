<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Core Diski</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Core_Diski_Demo.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark main-navbar mb-0">
            <div class="container-fluid px-4">
                <a class="brand-block" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/branding/corediski-logo.png" alt="Core Diski" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='grid';" />
                    <span class="brand-logo-fallback">⚽</span>
                    <span class="brand-text">
                        <strong>CORE DISKI</strong>
                        <small>Authentic Football Shirts</small>
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto ms-4 mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Shop</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Cart" asp-action="Index">Cart</a></li>
                    </ul>

                    <div class="utility-icons me-3 d-none d-lg-flex" aria-hidden="true">
                        <span class="utility-icon">⌂</span>
                        <span class="utility-icon">⌕</span>
                        <span class="utility-icon">♡</span>
                        <span class="utility-icon">⚑</span>
                        <span class="utility-icon">⚙</span>
                        <span class="utility-icon">◎</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-3">
                            <li class="nav-item"><span class="nav-link">Hi @User.Identity.Name</span></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                            }
                            <li class="nav-item">
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link">Logout</button>
                                </form>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav me-3">
                            <li class="nav-item"><a class="nav-link" href="/sign-in">Sign In</a></li>
                            <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <partial name="_Alerts" />
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container-fluid px-4">
            &copy; 2026 - Core Diski
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
