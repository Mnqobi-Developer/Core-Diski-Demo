@using Core_Diski_Demo.Models.Entities
@{
    ViewData["Title"] = "Catalog Setup";
    var leagues = ViewBag.Leagues as List<League> ?? new();
    var clubs = ViewBag.Clubs as List<Club> ?? new();
    var brands = ViewBag.Brands as List<Brand> ?? new();
    var categories = ViewBag.Categories as List<Category> ?? new();
}

<h1 class="h3 mb-3">Catalog Setup</h1>
<p class="text-muted">Add your leagues, clubs, brands, and categories before creating jerseys.</p>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <h2 class="h5">Add League</h2>
            <form asp-action="AddLeague" method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input name="name" class="form-control" placeholder="e.g. English Premier League" />
                <button class="btn btn-primary">Add</button>
            </form>
            <ul class="mt-3 mb-0">
                @foreach (var item in leagues) { <li>@item.Name</li> }
            </ul>
        </div></div>
    </div>

    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <h2 class="h5">Add Brand</h2>
            <form asp-action="AddBrand" method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input name="name" class="form-control" placeholder="e.g. Adidas" />
                <button class="btn btn-primary">Add</button>
            </form>
            <ul class="mt-3 mb-0">
                @foreach (var item in brands) { <li>@item.Name</li> }
            </ul>
        </div></div>
    </div>

    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <h2 class="h5">Add Category</h2>
            <form asp-action="AddCategory" method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input name="name" class="form-control" placeholder="e.g. Retro" />
                <button class="btn btn-primary">Add</button>
            </form>
            <ul class="mt-3 mb-0">
                @foreach (var item in categories) { <li>@item.Name</li> }
            </ul>
        </div></div>
    </div>

    <div class="col-md-6">
        <div class="card"><div class="card-body">
            <h2 class="h5">Add Club</h2>
            <form asp-action="AddClub" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-12"><input name="name" class="form-control" placeholder="Club name" /></div>
                <div class="col-12">
                    <select name="leagueId" class="form-select">
                        <option value="">Choose league...</option>
                        @foreach (var league in leagues)
                        {
                            <option value="@league.Id">@league.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12"><input name="country" class="form-control" placeholder="Country (optional)" /></div>
                <div class="col-12"><button class="btn btn-primary">Add</button></div>
            </form>
            <ul class="mt-3 mb-0">
                @foreach (var item in clubs) { <li>@item.Name (@item.League?.Name)</li> }
            </ul>
        </div></div>
    </div>
</div>
